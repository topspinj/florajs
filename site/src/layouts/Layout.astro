---
interface Props {
  title: string;
  description?: string;
  fullscreen?: boolean;
}

const { title, description = "The fault-tolerant diagram library for AI applications. Mermaid-compatible syntax, beautiful interactive SVGs.", fullscreen = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class:list={[{ fullscreen }]}>
    <nav class="nav">
      <div class="nav-inner">
        <a href={base} class="nav-logo">
          <img class="nav-icon" src={`${base}/logo.png`} alt="Flora logo" width="24" height="24" />
          Flora
        </a>
        <div class="nav-links">
          <a href="#features">Features</a>
          <a href={`${base}/docs`}>Docs</a>
          <a href={`${base}/playground/`}>Playground</a>
          <a href="https://github.com/topspinj/florajs" class="nav-gh">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-left">
          <span class="footer-logo">Flora</span>
          <span class="footer-sep">&middot;</span>
          <span>MIT License</span>
        </div>
        <div class="footer-right">
          <a href="https://github.com/topspinj/florajs">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  body.fullscreen {
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  body.fullscreen .footer {
    display: none;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .nav-logo:hover {
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-gh {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    padding: 24px;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--color-text-secondary);
  }

  .footer-right a {
    font-size: 14px;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-right a:hover {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
</style>
