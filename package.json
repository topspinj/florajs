{
  "name": "@topspinj/flora",
  "version": "0.1.0",
  "description": "Beautiful, interactive diagrams from Mermaid-compatible syntax",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./rehype": {
      "types": "./dist/rehype.d.ts",
      "import": "./dist/rehype.js",
      "require": "./dist/rehype.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test:run",
    "playground": "tsup && open http://localhost:3333/playground.html && python3 -m http.server 3333"
  },
  "keywords": [
    "diagrams",
    "flowchart",
    "erd",
    "svg",
    "mermaid",
    "visualization"
  ],
  "author": "topspinj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topspinj/florajs.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
