{
  "name": "florajs",
  "version": "0.1.0",
  "description": "Beautiful, interactive diagrams from Mermaid-compatible syntax",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "playground": "tsup && open http://localhost:3333/playground.html && python3 -m http.server 3333"
  },
  "keywords": [
    "diagrams",
    "flowchart",
    "erd",
    "svg",
    "mermaid",
    "visualization"
  ],
  "author": "topspinj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/topspinj/florajs"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.62.1"
  }
}
